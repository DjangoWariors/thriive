SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_NAME=thriive_dev
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
# Redis DB for the Django cache (prod only); keep separate from the broker on /0.
CACHE_URL=redis://localhost:6379/1
CORS_ALLOWED_ORIGINS=http://localhost:5173
THRIIVE_OTP_LENGTH=6
THRIIVE_OTP_EXPIRY_SECONDS=300
THRIIVE_MAX_LOGIN_ATTEMPTS=5
THRIIVE_LOCKOUT_MINUTES=30
# API rate limits (DRF). Format: <n>/<second|minute|hour|day>.
THRIIVE_THROTTLE_AUTH=20/min
THRIIVE_THROTTLE_OTP=5/min
THRIIVE_THROTTLE_BULK=5/hour
# Nightly achievement run: which TargetPeriod statuses to recompute, and the hour (0-23).
THRIIVE_ACHIEVEMENT_AUTO_STATUSES=published,locked
THRIIVE_ACHIEVEMENT_CRON_HOUR=2
