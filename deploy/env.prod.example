# Thriive IMS — production environment.
# setup.sh copies this to backend/.env and fills the __PLACEHOLDERS__.
# Loaded by python-decouple; DJANGO_SETTINGS_MODULE=config.settings.prod.

# --- Core ---
SECRET_KEY=__SECRET_KEY__
DEBUG=False
# Comma-separated hosts Django will serve — your EC2 public IP or DNS / domain.
ALLOWED_HOSTS=__DOMAIN__,localhost,127.0.0.1

# --- HTTPS enforcement ---
# setup.sh sets these to False for an IP/HTTP demo, True for a real domain.
# NEVER leave them False once you have TLS — flip to True and re-run deploy.sh.
SECURE_SSL_REDIRECT=__SSL__
SESSION_COOKIE_SECURE=__SSL__
CSRF_COOKIE_SECURE=__SSL__
# Origin trusted for admin/session POSTs (scheme matters).
CSRF_TRUSTED_ORIGINS=__SCHEME__://__DOMAIN__

# --- Database (PostgreSQL 17, local socket) ---
DB_NAME=__DB_NAME__
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PASSWORD__
DB_HOST=localhost
DB_PORT=5432

# --- Redis (Celery broker + result backend + Django cache) ---
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
CACHE_URL=redis://localhost:6379/1

# --- CORS: the frontend is served same-origin by Nginx, so this only matters
#     if you host the SPA on a different domain. Keep in sync with ALLOWED_HOSTS. ---
CORS_ALLOWED_ORIGINS=__SCHEME__://__DOMAIN__

# --- Auth / OTP ---
THRIIVE_OTP_LENGTH=6
THRIIVE_OTP_EXPIRY_SECONDS=300
THRIIVE_MAX_LOGIN_ATTEMPTS=5
THRIIVE_LOCKOUT_MINUTES=30

# --- API throttles (DRF) ---
THRIIVE_THROTTLE_AUTH=20/min
THRIIVE_THROTTLE_OTP=5/min
THRIIVE_THROTTLE_BULK=5/hour

# --- Nightly beats ---
THRIIVE_ACHIEVEMENT_AUTO_STATUSES=published,locked
THRIIVE_ACHIEVEMENT_CRON_HOUR=2
